---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div id="job-board-root"></div>
</Layout>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
/>

<style is:global>
	:root {
		--bg: #000000;
		--fg: #ededed;
		--fg-muted: #a1a1a1;
		--fg-subtle: #ededed99;
		--border: #1f1f1f;
		--border-strong: #2e2e2e;
		--panel: #0a0a0a;
		--panel-hover: #111111;
		--accent: #ffffff;
		--success: #0070f3;
		--font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
		--font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--fg);
		font-family: var(--font-sans);
		font-feature-settings: "ss01", "cv11";
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.jb-topbar {
		border-bottom: 1px solid var(--border);
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: saturate(180%) blur(8px);
		-webkit-backdrop-filter: saturate(180%) blur(8px);
	}

	.jb-topbar-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 16px 24px;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.jb-logo {
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.jb-logo svg {
		width: 22px;
		height: 22px;
		fill: var(--fg);
	}

	.jb-brand {
		font-weight: 600;
		letter-spacing: -0.01em;
		font-size: 15px;
	}

	.jb-brand-sep {
		color: var(--border-strong);
		font-weight: 400;
		margin: 0 2px;
	}

	.jb-brand-sub {
		color: var(--fg-muted);
		font-weight: 400;
	}

	.jb-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 56px 24px 96px;
	}

	.jb-header h1 {
		margin: 0 0 10px;
		font-size: 44px;
		font-weight: 600;
		letter-spacing: -0.035em;
		line-height: 1.05;
		color: var(--fg);
	}

	.jb-header p {
		margin: 0 0 40px;
		color: var(--fg-muted);
		font-size: 15px;
		letter-spacing: -0.01em;
	}

	.jb-layout {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 32px;
	}

	@media (max-width: 820px) {
		.jb-layout {
			grid-template-columns: 1fr;
		}
	}

	.jb-filters {
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 22px;
		height: fit-content;
		background: var(--panel);
	}

	.jb-filter-group {
		margin-bottom: 22px;
	}

	.jb-filter-group:last-of-type {
		margin-bottom: 0;
	}

	.jb-filter-label {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 12px;
		font-weight: 500;
	}

	.jb-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.jb-chip {
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		font-weight: 400;
		padding: 5px 10px;
		border-radius: 6px;
		cursor: pointer;
		transition:
			background 120ms ease,
			border-color 120ms ease,
			color 120ms ease;
		text-transform: capitalize;
	}

	.jb-chip:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.jb-chip.is-active {
		background: var(--fg);
		border-color: var(--fg);
		color: #000;
	}

	.jb-clear {
		margin-top: 18px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		padding: 8px 12px;
		border-radius: 6px;
		cursor: pointer;
		width: 100%;
		transition: border-color 120ms ease, color 120ms ease;
	}

	.jb-clear:hover {
		color: var(--fg);
		border-color: var(--border-strong);
	}

	.jb-results-meta {
		font-family: var(--font-mono);
		color: var(--fg-muted);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 16px;
	}

	.jb-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.jb-card {
		background: var(--panel);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 20px 22px;
		transition: border-color 120ms ease, background 120ms ease;
		cursor: pointer;
	}

	.jb-card:hover {
		border-color: var(--border-strong);
		background: var(--panel-hover);
	}

	.jb-card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 16px;
		margin-bottom: 4px;
	}

	.jb-card h3 {
		margin: 0;
		font-size: 15px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--fg);
	}

	.jb-card .jb-company {
		color: var(--fg-muted);
		font-size: 13px;
		margin-top: 2px;
	}

	.jb-card .jb-salary {
		font-family: var(--font-mono);
		color: var(--fg);
		font-size: 12.5px;
		white-space: nowrap;
		padding-top: 2px;
	}

	.jb-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 14px;
	}

	.jb-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 8px;
		border-radius: 4px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		text-transform: lowercase;
		letter-spacing: 0;
	}

	.jb-empty {
		text-align: center;
		color: var(--fg-muted);
		padding: 80px 20px;
		border: 1px dashed var(--border);
		border-radius: 12px;
		font-size: 14px;
	}

	.jb-modal-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 64px 24px;
		z-index: 50;
		overflow-y: auto;
		animation: jb-overlay-in 160ms ease-out;
	}

	@keyframes jb-overlay-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.jb-modal {
		width: 100%;
		max-width: 640px;
		background: var(--panel);
		border: 1px solid var(--border-strong);
		border-radius: 14px;
		padding: 28px 28px 24px;
		position: relative;
		animation: jb-modal-in 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	@keyframes jb-modal-in {
		from {
			opacity: 0;
			transform: translateY(8px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.jb-modal-close {
		position: absolute;
		top: 16px;
		right: 16px;
		width: 32px;
		height: 32px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: transparent;
		color: var(--fg-muted);
		cursor: pointer;
		transition: border-color 120ms ease, color 120ms ease;
	}

	.jb-modal-close:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.jb-modal-close svg {
		width: 14px;
		height: 14px;
	}

	.jb-modal-meta {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 10px;
	}

	.jb-modal h2 {
		margin: 0 0 6px;
		font-size: 24px;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.jb-modal-company {
		color: var(--fg-muted);
		font-size: 14px;
	}

	.jb-modal-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin: 16px 0 22px;
	}

	.jb-modal-pill {
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 8px;
		border-radius: 4px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		text-transform: lowercase;
	}

	.jb-modal-pill.salary {
		color: var(--fg);
		border-color: var(--border-strong);
	}

	.jb-modal-section {
		margin-bottom: 22px;
	}

	.jb-modal-section:last-of-type {
		margin-bottom: 0;
	}

	.jb-modal-section-label {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 10px;
		font-weight: 500;
	}

	.jb-modal-section p {
		margin: 0;
		font-size: 14px;
		line-height: 1.65;
		color: var(--fg);
	}

	.jb-modal-section ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.jb-modal-section li {
		font-size: 14px;
		line-height: 1.55;
		color: var(--fg);
		padding-left: 18px;
		position: relative;
	}

	.jb-modal-section li::before {
		content: '';
		position: absolute;
		left: 4px;
		top: 9px;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--fg-muted);
	}

	.jb-modal-actions {
		display: flex;
		gap: 8px;
		margin-top: 28px;
		padding-top: 20px;
		border-top: 1px solid var(--border);
	}

	.jb-btn {
		font-family: var(--font-sans);
		font-size: 13.5px;
		font-weight: 500;
		padding: 9px 16px;
		border-radius: 8px;
		cursor: pointer;
		border: 1px solid transparent;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		transition:
			background 120ms ease,
			border-color 120ms ease,
			color 120ms ease,
			opacity 120ms ease;
	}

	.jb-btn-primary {
		background: var(--fg);
		color: #000;
		border-color: var(--fg);
	}

	.jb-btn-primary:hover {
		opacity: 0.88;
	}

	.jb-btn-secondary {
		background: transparent;
		color: var(--fg);
		border-color: var(--border);
	}

	.jb-btn-secondary:hover {
		border-color: var(--border-strong);
	}

	.jb-btn svg {
		width: 12px;
		height: 12px;
	}
</style>

