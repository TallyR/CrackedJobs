---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div id="job-board-root"></div>
</Layout>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
/>

<style is:global>
	:root {
		--bg: #000000;
		--fg: #ededed;
		--fg-muted: #a1a1a1;
		--fg-subtle: #ededed99;
		--border: #1f1f1f;
		--border-strong: #2e2e2e;
		--panel: #0a0a0a;
		--panel-hover: #111111;
		--accent: #ffffff;
		--success: #0070f3;
		--font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
		--font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--fg);
		font-family: var(--font-sans);
		font-feature-settings: "ss01", "cv11";
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.jb-topbar {
		border-bottom: 1px solid var(--border);
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: saturate(180%) blur(8px);
		-webkit-backdrop-filter: saturate(180%) blur(8px);
	}

	.jb-topbar-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 16px 24px;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.jb-logo {
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.jb-logo svg {
		width: 22px;
		height: 22px;
		fill: var(--fg);
	}

	.jb-brand {
		font-weight: 600;
		letter-spacing: -0.01em;
		font-size: 15px;
	}

	.jb-brand-sep {
		color: var(--border-strong);
		font-weight: 400;
		margin: 0 2px;
	}

	.jb-brand-sub {
		color: var(--fg-muted);
		font-weight: 400;
	}

	.jb-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 56px 24px 96px;
	}

	.jb-header h1 {
		margin: 0 0 10px;
		font-size: 44px;
		font-weight: 600;
		letter-spacing: -0.035em;
		line-height: 1.05;
		color: var(--fg);
	}

	.jb-header p {
		margin: 0 0 40px;
		color: var(--fg-muted);
		font-size: 15px;
		letter-spacing: -0.01em;
	}

	.jb-layout {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 32px;
	}

	@media (max-width: 820px) {
		.jb-layout {
			grid-template-columns: 1fr;
		}
	}

	.jb-filters {
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 22px;
		height: fit-content;
		background: var(--panel);
	}

	.jb-filter-group {
		margin-bottom: 22px;
	}

	.jb-filter-group:last-of-type {
		margin-bottom: 0;
	}

	.jb-filter-label {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 12px;
		font-weight: 500;
	}

	.jb-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.jb-chip {
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		font-weight: 400;
		padding: 5px 10px;
		border-radius: 6px;
		cursor: pointer;
		transition:
			background 120ms ease,
			border-color 120ms ease,
			color 120ms ease;
		text-transform: capitalize;
	}

	.jb-chip:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.jb-chip.is-active {
		background: var(--fg);
		border-color: var(--fg);
		color: #000;
	}

	.jb-clear {
		margin-top: 18px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		padding: 8px 12px;
		border-radius: 6px;
		cursor: pointer;
		width: 100%;
		transition: border-color 120ms ease, color 120ms ease;
	}

	.jb-clear:hover {
		color: var(--fg);
		border-color: var(--border-strong);
	}

	.jb-results-meta {
		font-family: var(--font-mono);
		color: var(--fg-muted);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 16px;
	}

	.jb-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.jb-card {
		background: var(--panel);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 20px 22px;
		transition: border-color 120ms ease, background 120ms ease;
		cursor: pointer;
	}

	.jb-card:hover {
		border-color: var(--border-strong);
		background: var(--panel-hover);
	}

	.jb-card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 16px;
		margin-bottom: 4px;
	}

	.jb-card h3 {
		margin: 0;
		font-size: 15px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--fg);
	}

	.jb-card .jb-company {
		color: var(--fg-muted);
		font-size: 13px;
		margin-top: 2px;
	}

	.jb-card .jb-salary {
		font-family: var(--font-mono);
		color: var(--fg);
		font-size: 12.5px;
		white-space: nowrap;
		padding-top: 2px;
	}

	.jb-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 14px;
	}

	.jb-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 8px;
		border-radius: 4px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		text-transform: lowercase;
		letter-spacing: 0;
	}

	.jb-empty {
		text-align: center;
		color: var(--fg-muted);
		padding: 80px 20px;
		border: 1px dashed var(--border);
		border-radius: 12px;
		font-size: 14px;
	}
</style>

<script type="module">
	import { h, render } from 'https://esm.sh/preact@10.22.1';
	import { useMemo, useState } from 'https://esm.sh/preact@10.22.1/hooks';
	import htm from 'https://esm.sh/htm@3.1.1';

	const html = htm.bind(h);

	const LEVELS = ['junior', 'mid', 'senior', 'staff', 'senior staff'];
	const LOCATIONS = ['remote', 'new york city', 'san francisco', 'seattle'];
	const SPECIALTIES = [
		'infrastructure',
		'product engineer',
		'full stack',
		'AI',
		'security',
		'front end',
		'back end',
	];

	const JOBS = [
		{
			id: 1,
			title: 'Junior Frontend Engineer',
			company: 'Lumen Labs',
			salary: '$110k – $135k',
			level: 'junior',
			location: 'remote',
			specialty: 'front end',
		},
		{
			id: 2,
			title: 'Mid-Level Backend Engineer',
			company: 'Northwind Systems',
			salary: '$150k – $180k',
			level: 'mid',
			location: 'new york city',
			specialty: 'back end',
		},
		{
			id: 3,
			title: 'Senior Infrastructure Engineer',
			company: 'Gravity Cloud',
			salary: '$200k – $260k',
			level: 'senior',
			location: 'seattle',
			specialty: 'infrastructure',
		},
		{
			id: 4,
			title: 'Staff AI Engineer',
			company: 'Synapse AI',
			salary: '$280k – $360k',
			level: 'staff',
			location: 'san francisco',
			specialty: 'AI',
		},
		{
			id: 5,
			title: 'Senior Staff Security Engineer',
			company: 'Bastion Security',
			salary: '$330k – $420k',
			level: 'senior staff',
			location: 'remote',
			specialty: 'security',
		},
		{
			id: 6,
			title: 'Mid-Level Full Stack Engineer',
			company: 'Foundry',
			salary: '$155k – $185k',
			level: 'mid',
			location: 'san francisco',
			specialty: 'full stack',
		},
		{
			id: 7,
			title: 'Senior Product Engineer',
			company: 'Tessera',
			salary: '$210k – $260k',
			level: 'senior',
			location: 'new york city',
			specialty: 'product engineer',
		},
		{
			id: 8,
			title: 'Junior Backend Engineer',
			company: 'Polaris Pay',
			salary: '$115k – $140k',
			level: 'junior',
			location: 'seattle',
			specialty: 'back end',
		},
		{
			id: 9,
			title: 'Staff Infrastructure Engineer',
			company: 'Helix Compute',
			salary: '$290k – $370k',
			level: 'staff',
			location: 'remote',
			specialty: 'infrastructure',
		},
		{
			id: 10,
			title: 'Senior Frontend Engineer',
			company: 'Crescent',
			salary: '$200k – $245k',
			level: 'senior',
			location: 'san francisco',
			specialty: 'front end',
		},
		{
			id: 11,
			title: 'Mid-Level AI Engineer',
			company: 'Mira Research',
			salary: '$170k – $210k',
			level: 'mid',
			location: 'remote',
			specialty: 'AI',
		},
		{
			id: 12,
			title: 'Senior Staff Product Engineer',
			company: 'Atlas Commerce',
			salary: '$340k – $430k',
			level: 'senior staff',
			location: 'new york city',
			specialty: 'product engineer',
		},
		{
			id: 13,
			title: 'Senior Security Engineer',
			company: 'Vanta Shield',
			salary: '$215k – $270k',
			level: 'senior',
			location: 'seattle',
			specialty: 'security',
		},
		{
			id: 14,
			title: 'Staff Full Stack Engineer',
			company: 'Quill',
			salary: '$285k – $355k',
			level: 'staff',
			location: 'new york city',
			specialty: 'full stack',
		},
		{
			id: 15,
			title: 'Junior Product Engineer',
			company: 'Kindred',
			salary: '$120k – $145k',
			level: 'junior',
			location: 'remote',
			specialty: 'product engineer',
		},
	];

	function FilterGroup({ label, options, selected, onToggle }) {
		return html`
			<div class="jb-filter-group">
				<div class="jb-filter-label">${label}</div>
				<div class="jb-chips">
					${options.map(
						(opt) => html`
							<button
								key=${opt}
								type="button"
								class=${'jb-chip' + (selected.has(opt) ? ' is-active' : '')}
								onClick=${() => onToggle(opt)}
							>
								${opt}
							</button>
						`,
					)}
				</div>
			</div>
		`;
	}

	function JobCard({ job }) {
		return html`
			<div class="jb-card">
				<div class="jb-card-top">
					<div>
						<h3>${job.title}</h3>
						<div class="jb-company">${job.company}</div>
					</div>
					<div class="jb-salary">${job.salary}</div>
				</div>
				<div class="jb-tags">
					<span class="jb-tag level">${job.level}</span>
					<span class="jb-tag location">${job.location}</span>
					<span class="jb-tag specialty">${job.specialty}</span>
				</div>
			</div>
		`;
	}

	function JobBoard() {
		const [levels, setLevels] = useState(new Set());
		const [locations, setLocations] = useState(new Set());
		const [specialties, setSpecialties] = useState(new Set());

		const toggle = (setter) => (value) => {
			setter((prev) => {
				const next = new Set(prev);
				if (next.has(value)) next.delete(value);
				else next.add(value);
				return next;
			});
		};

		const clearAll = () => {
			setLevels(new Set());
			setLocations(new Set());
			setSpecialties(new Set());
		};

		const filtered = useMemo(() => {
			return JOBS.filter((job) => {
				if (levels.size && !levels.has(job.level)) return false;
				if (locations.size && !locations.has(job.location)) return false;
				if (specialties.size && !specialties.has(job.specialty)) return false;
				return true;
			});
		}, [levels, locations, specialties]);

		const totalActive = levels.size + locations.size + specialties.size;

		return html`
			<div>
				<header class="jb-topbar">
					<div class="jb-topbar-inner">
						<span class="jb-brand">jobs</span>
					</div>
				</header>
				<div class="jb-container">
				<div class="jb-header">
					<h1>Cracked jobs only.</h1>
					<p>Elite engineering roles at the highest-paying companies in tech.</p>
				</div>
				<div class="jb-layout">
					<aside class="jb-filters">
						<${FilterGroup}
							label="Level"
							options=${LEVELS}
							selected=${levels}
							onToggle=${toggle(setLevels)}
						/>
						<${FilterGroup}
							label="Location"
							options=${LOCATIONS}
							selected=${locations}
							onToggle=${toggle(setLocations)}
						/>
						<${FilterGroup}
							label="Specialty"
							options=${SPECIALTIES}
							selected=${specialties}
							onToggle=${toggle(setSpecialties)}
						/>
						${totalActive > 0 &&
						html`<button type="button" class="jb-clear" onClick=${clearAll}>
							Clear all filters
						</button>`}
					</aside>
					<section>
						<div class="jb-results-meta">
							Showing ${filtered.length} of ${JOBS.length} jobs
						</div>
						${filtered.length === 0
							? html`<div class="jb-empty">No jobs match your filters.</div>`
							: html`<div class="jb-list">
									${filtered.map((job) => html`<${JobCard} key=${job.id} job=${job} />`)}
								</div>`}
					</section>
				</div>
				</div>
			</div>
		`;
	}

	const root = document.getElementById('job-board-root');
	if (root) render(html`<${JobBoard} />`, root);
</script>
