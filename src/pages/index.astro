---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<div id="job-board-root"></div>
</Layout>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
	rel="stylesheet"
	href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
/>

<style is:global>
	:root {
		--bg: #000000;
		--fg: #ededed;
		--fg-muted: #a1a1a1;
		--fg-subtle: #ededed99;
		--border: #1f1f1f;
		--border-strong: #2e2e2e;
		--panel: #0a0a0a;
		--panel-hover: #111111;
		--accent: #ffffff;
		--success: #0070f3;
		--font-sans: "Geist", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto,
			"Helvetica Neue", Arial, sans-serif;
		--font-mono: "Geist Mono", ui-monospace, "SF Mono", Menlo, Consolas, monospace;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--fg);
		font-family: var(--font-sans);
		font-feature-settings: "ss01", "cv11";
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	.jb-topbar {
		border-bottom: 1px solid var(--border);
		background: rgba(0, 0, 0, 0.6);
		backdrop-filter: saturate(180%) blur(8px);
		-webkit-backdrop-filter: saturate(180%) blur(8px);
	}

	.jb-topbar-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 16px 24px;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.jb-logo {
		width: 22px;
		height: 22px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}

	.jb-logo svg {
		width: 22px;
		height: 22px;
		fill: var(--fg);
	}

	.jb-brand {
		font-weight: 600;
		letter-spacing: -0.01em;
		font-size: 15px;
		display: inline-flex;
		align-items: center;
		gap: 6px;
	}

	.jb-brand-emoji {
		font-size: 16px;
		line-height: 1;
	}

	.jb-brand-sep {
		color: var(--border-strong);
		font-weight: 400;
		margin: 0 2px;
	}

	.jb-brand-sub {
		color: var(--fg-muted);
		font-weight: 400;
	}

	.jb-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 56px 24px 96px;
	}

	.jb-header h1 {
		margin: 0 0 10px;
		font-size: 44px;
		font-weight: 600;
		letter-spacing: -0.035em;
		line-height: 1.05;
		color: var(--fg);
	}

	.jb-header p {
		margin: 0 0 40px;
		color: var(--fg-muted);
		font-size: 15px;
		letter-spacing: -0.01em;
	}

	.jb-layout {
		display: grid;
		grid-template-columns: 260px 1fr;
		gap: 32px;
	}

	@media (max-width: 820px) {
		.jb-layout {
			grid-template-columns: 1fr;
		}
	}

	.jb-filters {
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 22px;
		height: fit-content;
		background: var(--panel);
	}

	.jb-filter-group {
		margin-bottom: 22px;
	}

	.jb-filter-group:last-of-type {
		margin-bottom: 0;
	}

	.jb-filter-label {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 12px;
		font-weight: 500;
	}

	.jb-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}

	.jb-chip {
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		font-weight: 400;
		padding: 5px 10px;
		border-radius: 6px;
		cursor: pointer;
		transition:
			background 120ms ease,
			border-color 120ms ease,
			color 120ms ease;
		text-transform: capitalize;
	}

	.jb-chip:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.jb-chip.is-active {
		background: var(--fg);
		border-color: var(--fg);
		color: #000;
	}

	.jb-clear {
		margin-top: 18px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		font-family: var(--font-sans);
		font-size: 12.5px;
		padding: 8px 12px;
		border-radius: 6px;
		cursor: pointer;
		width: 100%;
		transition: border-color 120ms ease, color 120ms ease;
	}

	.jb-clear:hover {
		color: var(--fg);
		border-color: var(--border-strong);
	}

	.jb-results-meta {
		font-family: var(--font-mono);
		color: var(--fg-muted);
		font-size: 12px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		margin-bottom: 16px;
	}

	.jb-list {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.jb-card {
		background: var(--panel);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 20px 22px;
		transition: border-color 120ms ease, background 120ms ease;
		cursor: pointer;
	}

	.jb-card:hover {
		border-color: var(--border-strong);
		background: var(--panel-hover);
	}

	.jb-card-top {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 16px;
		margin-bottom: 4px;
	}

	.jb-card h3 {
		margin: 0;
		font-size: 15px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--fg);
	}

	.jb-card .jb-company {
		color: var(--fg-muted);
		font-size: 13px;
		margin-top: 2px;
	}

	.jb-card .jb-salary {
		font-family: var(--font-mono);
		color: var(--fg);
		font-size: 12.5px;
		white-space: nowrap;
		padding-top: 2px;
	}

	.jb-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 14px;
	}

	.jb-tag {
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 8px;
		border-radius: 4px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		text-transform: lowercase;
		letter-spacing: 0;
	}

	.jb-tag.posted {
		display: inline-flex;
		align-items: center;
		gap: 5px;
		margin-left: auto;
		border-style: dashed;
		color: #00ff41;
		border-color: rgba(0, 255, 65, 0.35);
		text-shadow: 0 0 8px rgba(0, 255, 65, 0.35);
	}

	.jb-tag.posted svg {
		width: 10px;
		height: 10px;
		flex-shrink: 0;
		opacity: 0.95;
	}

	.jb-empty {
		text-align: center;
		color: var(--fg-muted);
		padding: 80px 20px;
		border: 1px dashed var(--border);
		border-radius: 12px;
		font-size: 14px;
	}

	.jb-modal-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		display: flex;
		align-items: flex-start;
		justify-content: center;
		padding: 64px 24px;
		z-index: 50;
		overflow-y: auto;
		animation: jb-overlay-in 160ms ease-out;
	}

	@keyframes jb-overlay-in {
		from {
			opacity: 0;
		}
		to {
			opacity: 1;
		}
	}

	.jb-modal {
		width: 100%;
		max-width: 640px;
		background: var(--panel);
		border: 1px solid var(--border-strong);
		border-radius: 14px;
		padding: 28px 28px 24px;
		position: relative;
		animation: jb-modal-in 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	@keyframes jb-modal-in {
		from {
			opacity: 0;
			transform: translateY(8px) scale(0.98);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.jb-modal-close {
		position: absolute;
		top: 16px;
		right: 16px;
		width: 32px;
		height: 32px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border: 1px solid var(--border);
		border-radius: 8px;
		background: transparent;
		color: var(--fg-muted);
		cursor: pointer;
		transition: border-color 120ms ease, color 120ms ease;
	}

	.jb-modal-close:hover {
		border-color: var(--border-strong);
		color: var(--fg);
	}

	.jb-modal-close svg {
		width: 14px;
		height: 14px;
	}

	.jb-modal-meta {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 10px;
	}

	.jb-modal h2 {
		margin: 0 0 6px;
		font-size: 24px;
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.2;
	}

	.jb-modal-company {
		color: var(--fg-muted);
		font-size: 14px;
	}

	.jb-modal-pills {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin: 16px 0 22px;
	}

	.jb-modal-pill {
		font-family: var(--font-mono);
		font-size: 11px;
		padding: 3px 8px;
		border-radius: 4px;
		background: transparent;
		border: 1px solid var(--border);
		color: var(--fg-muted);
		text-transform: lowercase;
	}

	.jb-modal-pill.salary {
		color: var(--fg);
		border-color: var(--border-strong);
	}

	.jb-modal-section {
		margin-bottom: 22px;
	}

	.jb-modal-section:last-of-type {
		margin-bottom: 0;
	}

	.jb-modal-section-label {
		font-family: var(--font-mono);
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--fg-muted);
		margin-bottom: 10px;
		font-weight: 500;
	}

	.jb-modal-section p {
		margin: 0;
		font-size: 14px;
		line-height: 1.65;
		color: var(--fg);
	}

	.jb-modal-section ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.jb-modal-section li {
		font-size: 14px;
		line-height: 1.55;
		color: var(--fg);
		padding-left: 18px;
		position: relative;
	}

	.jb-modal-section li::before {
		content: '';
		position: absolute;
		left: 4px;
		top: 9px;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--fg-muted);
	}

	.jb-modal-actions {
		display: flex;
		gap: 8px;
		margin-top: 28px;
		padding-top: 20px;
		border-top: 1px solid var(--border);
	}

	.jb-btn {
		font-family: var(--font-sans);
		font-size: 13.5px;
		font-weight: 500;
		padding: 9px 16px;
		border-radius: 8px;
		cursor: pointer;
		border: 1px solid transparent;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 6px;
		transition:
			background 120ms ease,
			border-color 120ms ease,
			color 120ms ease,
			opacity 120ms ease;
	}

	.jb-btn-primary {
		background: var(--fg);
		color: #000;
		border-color: var(--fg);
	}

	.jb-btn-primary:hover {
		opacity: 0.88;
	}

	.jb-btn-secondary {
		background: transparent;
		color: var(--fg);
		border-color: var(--border);
	}

	.jb-btn-secondary:hover {
		border-color: var(--border-strong);
	}

	.jb-btn svg {
		width: 12px;
		height: 12px;
	}
</style>

<script type="module">
	import { h, render } from 'https://esm.sh/preact@10.22.1';
	import { useEffect, useMemo, useState } from 'https://esm.sh/preact@10.22.1/hooks';
	import htm from 'https://esm.sh/htm@3.1.1';

	const html = htm.bind(h);

	const LEVELS = ['junior', 'mid', 'senior', 'staff', 'senior staff'];
	const LOCATIONS = ['remote', 'new york city', 'san francisco', 'seattle'];
	const SPECIALTIES = [
		'infrastructure',
		'product engineer',
		'full stack',
		'AI',
		'security',
		'front end',
		'back end',
		'iOS',
		'Android',
	];

	const JOBS_URL = '/jobs.json';

	function FilterGroup({ label, options, selected, onToggle }) {
		return html`
			<div class="jb-filter-group">
				<div class="jb-filter-label">${label}</div>
				<div class="jb-chips">
					${options.map(
						(opt) => html`
							<button
								key=${opt}
								type="button"
								class=${'jb-chip' + (selected.has(opt) ? ' is-active' : '')}
								onClick=${() => onToggle(opt)}
							>
								${opt}
							</button>
						`,
					)}
				</div>
			</div>
		`;
	}

	function JobCard({ job, onSelect }) {
		const handleKeyDown = (e) => {
			if (e.key === 'Enter' || e.key === ' ') {
				e.preventDefault();
				onSelect(job);
			}
		};
		return html`
			<div
				class="jb-card"
				role="button"
				tabIndex="0"
				onClick=${() => onSelect(job)}
				onKeyDown=${handleKeyDown}
			>
				<div class="jb-card-top">
					<div>
						<h3>${job.company}</h3>
						<div class="jb-company">${job.title}</div>
					</div>
					<div class="jb-salary">${job.salary}</div>
				</div>
				<div class="jb-tags">
					<span class="jb-tag level">${job.level}</span>
					<span class="jb-tag location">${job.location}</span>
					<span class="jb-tag specialty">${job.specialty}</span>
					<span class="jb-tag posted">
						<svg
							viewBox="0 0 16 16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							aria-hidden="true"
						>
							<circle cx="8" cy="8" r="6" />
							<path d="M8 5v3.2l2 1.6" stroke-linecap="round" />
						</svg>
						${job.posted}
					</span>
				</div>
			</div>
		`;
	}

	function JobModal({ job, onClose }) {
		useEffect(() => {
			const onKey = (e) => {
				if (e.key === 'Escape') onClose();
			};
			document.addEventListener('keydown', onKey);
			const prevOverflow = document.body.style.overflow;
			document.body.style.overflow = 'hidden';
			return () => {
				document.removeEventListener('keydown', onKey);
				document.body.style.overflow = prevOverflow;
			};
		}, [onClose]);

		const onOverlayClick = (e) => {
			if (e.target === e.currentTarget) onClose();
		};

		return html`
			<div
				class="jb-modal-overlay"
				role="dialog"
				aria-modal="true"
				aria-labelledby="jb-modal-title"
				onClick=${onOverlayClick}
			>
				<div class="jb-modal">
					<button
						type="button"
						class="jb-modal-close"
						aria-label="Close"
						onClick=${onClose}
					>
						<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
							<path d="M4 4l8 8M12 4l-8 8" />
						</svg>
					</button>
					<div class="jb-modal-meta">${job.posted}</div>
					<h2 id="jb-modal-title">${job.title}</h2>
					<div class="jb-modal-company">${job.company}</div>
					<div class="jb-modal-pills">
						<span class="jb-modal-pill salary">${job.salary}</span>
						<span class="jb-modal-pill">${job.level}</span>
						<span class="jb-modal-pill">${job.location}</span>
						<span class="jb-modal-pill">${job.specialty}</span>
					</div>
					<div class="jb-modal-section">
						<div class="jb-modal-section-label">About the role</div>
						<p>${job.description}</p>
					</div>
					<div class="jb-modal-section">
						<div class="jb-modal-section-label">What you'll do</div>
						<ul>
							${job.responsibilities.map((r) => html`<li key=${r}>${r}</li>`)}
						</ul>
					</div>
					<div class="jb-modal-section">
						<div class="jb-modal-section-label">What we're looking for</div>
						<ul>
							${job.requirements.map((r) => html`<li key=${r}>${r}</li>`)}
						</ul>
					</div>
					<div class="jb-modal-actions">
						<a
							class="jb-btn jb-btn-primary"
							href=${job.applyUrl}
							target="_blank"
							rel="noopener noreferrer"
						>
							Apply now
							<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
								<path d="M3 8h10M9 4l4 4-4 4" />
							</svg>
						</a>
						<button type="button" class="jb-btn jb-btn-secondary" onClick=${onClose}>
							Close
						</button>
					</div>
				</div>
			</div>
		`;
	}

	function JobBoard() {
		const [levels, setLevels] = useState(new Set());
		const [locations, setLocations] = useState(new Set());
		const [specialties, setSpecialties] = useState(new Set());
		const [selectedJob, setSelectedJob] = useState(null);
		const [jobs, setJobs] = useState(null);
		const [error, setError] = useState(null);

		useEffect(() => {
			let cancelled = false;
			fetch(JOBS_URL)
				.then((res) => {
					if (!res.ok) throw new Error('Failed to load jobs (' + res.status + ')');
					return res.json();
				})
				.then((data) => {
					if (!cancelled) setJobs(data);
				})
				.catch((err) => {
					if (!cancelled) setError(err.message || String(err));
				});
			return () => {
				cancelled = true;
			};
		}, []);

		const toggle = (setter) => (value) => {
			setter((prev) => {
				const next = new Set(prev);
				if (next.has(value)) next.delete(value);
				else next.add(value);
				return next;
			});
		};

		const clearAll = () => {
			setLevels(new Set());
			setLocations(new Set());
			setSpecialties(new Set());
		};

		const filtered = useMemo(() => {
			if (!jobs) return [];
			return jobs.filter((job) => {
				if (levels.size && !levels.has(job.level)) return false;
				if (locations.size && !locations.has(job.location)) return false;
				if (specialties.size && !specialties.has(job.specialty)) return false;
				return true;
			});
		}, [jobs, levels, locations, specialties]);

		const totalActive = levels.size + locations.size + specialties.size;
		const isLoading = jobs === null && !error;

		return html`
			<div>
				<header class="jb-topbar">
					<div class="jb-topbar-inner">
						<span class="jb-brand">made in nyc <span class="jb-brand-emoji">🗽</span></span>
					</div>
				</header>
				<div class="jb-container">
				<div class="jb-header">
					<h1>Cracked jobs only.</h1>
					<p>Elite engineering roles at the highest paying companies in tech.</p>
				</div>
				<div class="jb-layout">
					<aside class="jb-filters">
						<${FilterGroup}
							label="Level"
							options=${LEVELS}
							selected=${levels}
							onToggle=${toggle(setLevels)}
						/>
						<${FilterGroup}
							label="Location"
							options=${LOCATIONS}
							selected=${locations}
							onToggle=${toggle(setLocations)}
						/>
						<${FilterGroup}
							label="Specialty"
							options=${SPECIALTIES}
							selected=${specialties}
							onToggle=${toggle(setSpecialties)}
						/>
						${totalActive > 0 &&
						html`<button type="button" class="jb-clear" onClick=${clearAll}>
							Clear all filters
						</button>`}
					</aside>
					<section>
						<div class="jb-results-meta">
							${isLoading
								? 'Loading jobs…'
								: error
									? 'Failed to load jobs'
									: 'Showing ' + filtered.length + ' of ' + jobs.length + ' jobs'}
						</div>
						${isLoading
							? html`<div class="jb-empty">Loading jobs…</div>`
							: error
								? html`<div class="jb-empty">${error}</div>`
								: filtered.length === 0
									? html`<div class="jb-empty">No jobs match your filters.</div>`
									: html`<div class="jb-list">
											${filtered.map(
												(job) => html`<${JobCard}
													key=${job.id}
													job=${job}
													onSelect=${setSelectedJob}
												/>`,
											)}
										</div>`}
					</section>
				</div>
				</div>
				${selectedJob &&
				html`<${JobModal} job=${selectedJob} onClose=${() => setSelectedJob(null)} />`}
			</div>
		`;
	}

	const root = document.getElementById('job-board-root');
	if (root) render(html`<${JobBoard} />`, root);
</script>
